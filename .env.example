# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather. Leave empty to disable bot polling (landing still works).
BOT_TOKEN=

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true  → deterministic mock responses, zero cost, no API keys needed
# false → real LLM calls (set at least one key below)
DEMO_MODE=true

# ── LLM provider (DEMO_MODE=false only) ───────────────────────────────────────
# Option A: OpenAI or compatible (Groq, Together, OpenRouter …)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4o-mini

# Option B: Anthropic
ANTHROPIC_API_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
# Port for HTTP mode (ignored in HTTPS mode — Caddy binds 80/443)
PORT=8080

# ── HTTPS via Caddy (optional) ────────────────────────────────────────────────
# Requires a domain pointing to this server's IP.
# Run:  docker compose --profile https up -d
DOMAIN=demo.example.com
ACME_EMAIL=admin@example.com

# ── Redis ─────────────────────────────────────────────────────────────────────
# Set automatically inside docker-compose. Override only for external Redis.
# REDIS_URL=redis://redis:6379/0
