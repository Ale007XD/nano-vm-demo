# ── Telegram bot token (get from @BotFather) ──────────────────────────────────
# Leave empty to disable bot polling and run landing only.
BOT_TOKEN=

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true  → no real LLM calls, deterministic mock responses, zero cost
# false → real LLM (requires at least one API key below)
DEMO_MODE=true

# ── LLM provider (only needed when DEMO_MODE=false) ───────────────────────────
# Option A: OpenAI or any OpenAI-compatible endpoint (Groq, Together, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4o-mini

# Option B: Anthropic
ANTHROPIC_API_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
# Port exposed on the host (frontend → nginx)
PORT=8080
